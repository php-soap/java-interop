{
    "name": "php-soap/java-interop",
    "description": "Cross-stack SOAP interop tests: php-soap middlewares against a Dockerised Apache WSS4J oracle.",
    "license": "MIT",
    "type": "project",
    "autoload-dev": {
        "psr-4": {
            "SoapInterop\\Tests\\": "tests/"
        }
    },
    "repositories": {
        "wsse-middleware": {
            "type": "path",
            "url": "../http-wsse-middleware",
            "options": {
                "symlink": false
            }
        },
        "attachments-middleware": {
            "type": "path",
            "url": "../psr18-attachments-middleware",
            "options": {
                "symlink": false
            }
        }
    },
    "require": {
        "php": "~8.4.0 || ~8.5.0",
        "ext-dom": "*",
        "ext-openssl": "*",
        "php-soap/psr18-wsse-middleware": "dev-feature/wsse-engine-modernization",
        "php-soap/psr18-attachments-middleware": "dev-feature/migrate-to-psl-mime",
        "nyholm/psr7": "^1.8",
        "symfony/http-client": "^7.1"
    },
    "require-dev": {
        "phpunit/phpunit": "~12.3"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
